# Copie para .env — Project Settings → API
# https://supabase.com/dashboard

# Project URL (ex.: https://xxxxx.supabase.co)
VITE_SUPABASE_URL=

# Chave publicável (Publishable / anon) — segura no navegador com RLS
VITE_SUPABASE_ANON_KEY=

# NUNCA coloque a chave Secret (sb_secret_...) aqui com prefixo VITE_;
# ela vazaria no bundle. Use só em backend / Edge Functions.
