# Copie para .env.local — Supabase → Project Settings → API
# Use o valor completo do campo "Project URL" (não monte o link na mão).

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_ou_publicavel

# Nunca commite .env.local com segredos reais.
# Não use service_role no browser.
